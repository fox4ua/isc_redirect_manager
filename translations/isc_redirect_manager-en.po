msgid "Увімкнути розширене журналювання"
msgstr "Enable extended logging"

msgid "Записувати додаткові діагностичні повідомлення для перевірок збігів, пропусків і fallback-сценаріїв редиректу."
msgstr "Write additional diagnostic messages for redirect match, skip, and fallback checks."

msgid "Вікно тротлінгу журналу помилок (секунди)"
msgstr "Failure log throttling window (seconds)"

msgid "Однакові записи про помилки в межах цього часового вікна зберігаються лише один раз. Встановіть 0, щоб вимкнути тротлінг."
msgstr "Identical failure entries within this time window are stored only once. Set 0 to disable throttling."

msgid "Максимальна кількість записів журналу помилок"
msgstr "Maximum failure log entries"

msgid "Скільки рядків зберігати в таблиці журналу помилок редиректу."
msgstr "How many rows to keep in the redirect failure log table."

msgid "Максимальна кількість статистичних записів"
msgstr "Maximum statistics entries"

msgid "Скільки лічильників спрацювань правил зберігати в таблиці статистики редиректів."
msgstr "How many rule hit counters to keep in the redirect statistics table."

msgid "Правило"
msgstr "Rule"

msgid "Останнє спрацювання"
msgstr "Last triggered"

msgid "ID останнього матеріалу"
msgstr "Last node ID"

msgid "Останнє місце призначення"
msgstr "Last destination"

msgid "Статистика редиректів поки що відсутня."
msgstr "No redirect statistics yet."

msgid "Час"
msgstr "Time"

msgid "Подія"
msgstr "Event"

msgid "ID матеріалу"
msgstr "Node ID"

msgid "Мова"
msgstr "Language"

msgid "Базове місце призначення"
msgstr "Base destination"

msgid "Сформоване місце призначення"
msgstr "Built destination"

msgid "Причина"
msgstr "Reason"

msgid "Помилки редиректу ще не зафіксовано."
msgstr "No redirect failures logged yet."

msgid "Перегляд правил ISC Redirect"
msgstr "View ISC redirect rules"

msgid "Перегляд сторінок адміністрування правил редиректу."
msgstr "View redirect rules administration screens."

msgid "Створення та редагування правил ISC Redirect"
msgstr "Create and edit ISC redirect rules"

msgid "Створення, редагування, зміна порядку, попередній перегляд, увімкнення та вимкнення правил редиректу."
msgstr "Create, edit, reorder, preview, and enable or disable redirect rules."

msgid "Видалення правил ISC Redirect"
msgstr "Delete ISC redirect rules"

msgid "Видалення правил редиректу."
msgstr "Delete redirect rules."

msgid "Перегляд журналу ISC Redirect"
msgstr "View ISC redirect logs"

msgid "Перегляд журналу fallback-помилок редиректу."
msgstr "View redirect fallback logs."

msgid "Перегляд статистики ISC Redirect"
msgstr "View ISC redirect statistics"

msgid "Перегляд статистики використання правил редиректу."
msgstr "View redirect usage statistics."

msgid "Керування налаштуваннями ISC Redirect"
msgstr "Administer ISC redirect settings"

msgid "Зміна налаштувань розширеного журналювання та зберігання даних."
msgstr "Change extended logging and data retention settings."

msgid "Повне адміністрування правил ISC Redirect"
msgstr "Administer ISC redirect rules"

msgid "Повний доступ до всіх операцій і налаштувань правил ISC Redirect."
msgstr "Full access to all ISC redirect rule operations and settings."
